# VocaForm rebuild: OpenAI API configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=high
OPENAI_VERIFICATION_MODEL=gpt-5.6-sol
OPENAI_VERIFICATION_REASONING_MODE=standard
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_SPEED=0.95
OPENAI_REALTIME_REASONING_EFFORT=low
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_LANGUAGE=
OPENAI_SAFETY_IDENTIFIER=

# Local server
HOST=127.0.0.1
PORT=5177
VOCAFORM_PUBLIC_DEMO=false
VOCAFORM_STORAGE_MODE=local
VOCAFORM_WORK_DIR=
SOFFICE_BIN=soffice

# Deterministic web-form browser hardening
VOCAFORM_WEBFORM_NATIVE_PREPARATION=true
VOCAFORM_WEBFORM_INSPECTION_TIMEOUT_MS=30000
VOCAFORM_WEBFORM_ACTION_TIMEOUT_MS=10000
VOCAFORM_WEBFORM_SESSION_TTL_MS=900000
VOCAFORM_WEBFORM_MAX_CONCURRENT_SESSIONS=4
VOCAFORM_WEBFORM_MAX_REQUESTS=300

# Optional scheduled live contract checks; use disposable public forms only
VOCAFORM_WEBFORM_LIVE_CHECKS=false
VOCAFORM_LIVE_GOOGLE_FORM_URL=
VOCAFORM_LIVE_MICROSOFT_FORM_URL=

# Legacy scaffold overrides (temporary compatibility)
FORM_SCHEMA_PATH=
FORM_TEMPLATE_PATH=
SESSION_STATE_PATH=
FAMILY_PROFILE_PATH=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=~openai/gpt-latest
OPENROUTER_REFERER=http://localhost
OPENROUTER_TITLE=Voice Form Filler
OPENROUTER_DATA_COLLECTION=deny
